# Database - use SQLite for local dev (no setup required), or PostgreSQL for production
# SQLite (creates roofvision.db in backend folder):
DATABASE_URL=sqlite:///./roofvision.db
# PostgreSQL (create DB first: createdb roofvision):
# DATABASE_URL=postgresql://user:password@localhost:5432/roofvision

# Optional
DEBUG=false

# --- Image generation (see docs/IMAGE-GEN-API.md) ---
# mock = copy uploaded image as "result" (no external API)
# IMAGE_GEN_PROVIDER=mock
IMAGE_GEN_PROVIDER=gemini
IMAGE_GEN_API_KEY=your_google_ai_api_key_here
IMAGE_GEN_MODEL=gemini-3.1-flash-image-preview
IMAGE_GEN_TIMEOUT_SECONDS=180
IMAGE_GEN_MAX_RETRIES=2
IMAGE_GEN_RETRY_BACKOFF_SECONDS=1.5
